tunnel: YOUR_TUNNEL_ID
credentials-file: /home/YOUR_WSL_USER/.cloudflared/YOUR_TUNNEL_ID.json

ingress:
  - hostname: legal-ai.iamspiderman.me
    path: /api/v1/chatbot/.*
    service: http://127.0.0.1:8000

  - hostname: legal-ai.iamspiderman.me
    path: /api/.*
    service: http://127.0.0.1:3001

  - hostname: legal-ai.iamspiderman.me
    path: /health
    service: http://127.0.0.1:8000

  - service: http_status:404
